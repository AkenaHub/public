end

local function buildLoadPlan(names, stallTime)
	local count  = #names
	local plan   = {}
	local t      = 0
	local burstEnd  = stallTime * 0.30
	local stallEnd  = stallTime * 0.70
	local burstCount = math.floor(count * 0.40)
	local stallCount = math.floor(count * 0.20)
	local finalCount = count - burstCount - stallCount

	for i = 1, burstCount do
		t = t + (burstEnd / burstCount) * (0.6 + math.random() * 0.8)
		table.insert(plan, { time = math.min(t, burstEnd * 0.98), name = names[i] })
	end
	local stallLen = stallEnd - burstEnd
	for i = 1, stallCount do
		t = burstEnd + (stallLen * i / stallCount) * (0.8 + math.random() * 0.4)
		table.insert(plan, { time = math.min(t, stallEnd * 0.98), name = names[burstCount + i] })
	end
	local finalLen = stallTime * 0.95 - stallEnd
	for i = 1, finalCount do
		t = stallEnd + (finalLen * i / finalCount)
		table.insert(plan, { time = math.min(t, stallTime * 0.95), name = names[burstCount + stallCount + i] })
	end
	table.sort(plan, function(a, b) return a.time < b.time end)
	return plan
end

