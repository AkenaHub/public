local function loadimg(url)
    if not (writefile and getcustomasset and (http_request or request or (syn and syn.request))) then
        warn("[Lumin]: Missing executor functions - (writefile/getcustomasset/request)")
        return nil
    end

    local http = http_request or request or (syn and syn.request)
    if not http then return nil end

    local ok, res = pcall(http, {
        Url = url,
        Method = "GET"
    })

    if not ok or not res or not res.Body then return nil end
    local filename = "ethos_" .. tostring(os.time()) .. ".png"
    local write_ok, write_err = pcall(writefile, filename, res.Body)
    if not write_ok then return nil end
    local asset_ok, asset_path = pcall(getcustomasset, filename)
    if not asset_ok or not asset_path then return nil end

    return asset_path
end

local function gatherAssetNames()
	local names = {}
	local seen  = {}
	local function add(n)
		if not seen[n] then seen[n] = true; table.insert(names, n) end
	end
	local function scan(parent, depth)
		if depth > 2 then return end
		for _, child in ipairs(parent:GetChildren()) do
			if child:IsA("ModuleScript") or child:IsA("LocalScript") or child:IsA("Script") then
				add(child.Name)
			elseif child:IsA("Folder") or child:IsA("Model") then
				add(child.Name)
				scan(child, depth + 1)
			end
		end
	end
	pcall(scan, ReplicatedStorage, 0)
	pcall(scan, game:GetService("Workspace"), 0)
	if #names < 8 then
		for _, v in ipairs({
			"CoreFramework","NetworkBridge","DataManager","EntityRegistry",
			"AudioController","UIManager","PhysicsEngine","EventBus",
			"SessionHandler","RenderPipeline","InputRouter","AssetCache",
			"StateManager","AnimationRig","LightingPass","SoundMixer",
			"CharacterHandler","RemoteRegistry","ToolManager","MapLoader",
		}) do add(v) end
	end
	for i = #names, 2, -1 do
		local j = math.random(i)
		names[i], names[j] = names[j], names[i]
	end
	return names
end

